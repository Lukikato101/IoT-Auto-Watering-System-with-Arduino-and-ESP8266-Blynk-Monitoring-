# IoT Watering System - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# DATABASE CONFIGURATION
# ============================================

# For development (SQLite - default if not set):
# DATABASE_URL=sqlite:///./iot_watering.db

# For production (PostgreSQL):
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/iot_watering

# For production (PostgreSQL on remote server):
# DATABASE_URL=postgresql://user:password@db.example.com:5432/iot_watering

# ============================================
# APPLICATION CONFIGURATION
# ============================================

# Environment: development or production
ENVIRONMENT=development

# Allowed CORS origins (comma-separated for multiple origins)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================
# FRONTEND CONFIGURATION
# ============================================

# Backend API URL for frontend
REACT_APP_API_URL=http://localhost:8000

# ============================================
# SENSOR SIMULATOR CONFIGURATION
# ============================================

# API URL for simulator
API_URL=http://localhost:8000

# Interval between sensor readings (seconds)
INTERVAL=5

# Moisture value range (simulated)
MIN_MOISTURE=300
MAX_MOISTURE=800

# ============================================
# LOGGING CONFIGURATION (Optional)
# ============================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: standard, json
LOG_FORMAT=standard

# ============================================
# SECURITY (Optional)
# ============================================

# Secret key for session management (if implemented)
# SECRET_KEY=your-secret-key-here-change-in-production

# ============================================
# NOTES FOR PRODUCTION DEPLOYMENT
# ============================================

# 1. Change ENVIRONMENT to "production"
# 2. Use a strong, unique DATABASE_URL password
# 3. Set ALLOWED_ORIGINS to your actual domain
# 4. Use HTTPS for all connections
# 5. Never commit .env file to version control
# 6. Use a secrets manager (AWS Secrets Manager, Azure Key Vault, etc.)
